# DeepSeek V4 is the platform LLM (spec §8). The platform also auto-loads the key
# from the parent syberAgent/.env if present, so you may not need this file.
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Optional overrides:
# SYBER_ORCH_MODEL=deepseek-reasoner     # orchestrator + threat investigator (v4-pro tier)
# SYBER_SUB_MODEL=deepseek-chat          # structured-extraction subagents (v4-flash tier)
# SYBER_INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection  # real classifier (needs torch)
# SYBER_SBERT_MODEL=all-MiniLM-L6-v2     # real SBERT embeddings (needs sentence-transformers)
# NEO4J_URI=bolt://localhost:7687        # switch graph backend to Neo4j
