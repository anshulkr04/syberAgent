# DeepSeek V4 is the platform LLM (spec §8). The platform also auto-loads the key
# from the parent syberAgent/.env if present, so you may not need this file.
DEEPSEEK_API_KEY=sk-your-deepseek-key
# Optional overrides:
# SYBER_ORCH_MODEL=deepseek-reasoner     # orchestrator + threat investigator (v4-pro tier)
# SYBER_SUB_MODEL=deepseek-chat          # structured-extraction subagents (v4-flash tier)
# SYBER_INJECTION_MODEL=protectai/deberta-v3-base-prompt-injection  # real classifier (needs torch)
# SYBER_SBERT_MODEL=all-MiniLM-L6-v2     # real SBERT embeddings (needs sentence-transformers)
# NEO4J_URI=bolt://localhost:7687        # switch graph backend to Neo4j

# --- Emailed reports (Resend) --------------------------------------------- #
# Lets the agent email a verifiable engagement report with PROOFS attached
# (downloaded data samples + screenshots) via syber_send_report.
# RESEND_API_KEY=re_your_resend_key
# SYBER_REPORT_TO=you@example.com        # recipient (default sender only delivers to your Resend account email)
# SYBER_REPORT_FROM=Syber <reports@yourverifieddomain.com>  # set to a Resend-verified domain to email anyone

# --- Subdomain enumeration (optional free key to widen passive-DNS coverage) - #
# AlienVault OTX passive DNS. Unauthenticated is 429-throttled; a FREE key (from
# otx.alienvault.com) makes it a strong source. Everything else is keyless
# (subfinder free sources + certspotter + crt.sh + hackertarget + urlscan + wayback).
# OTX_API_KEY=your_free_otx_key
