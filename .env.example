DEEPSEEK_API_KEY=

# --- AgentMail: programmatic inboxes for provisioning test accounts (IDOR/BOLA) ---
# Touches only the agent's OWN AgentMail account, never the target.
AGENTMAIL_API_KEY=

# --- AgentPhone: a real number to RECEIVE SMS OTP during test-account signup ------
# Obtain via one-time signup (scripts/syber_phone_signup.sh). Receive-only by design;
# outbound is restricted to SYBER_OPERATOR_PHONE (the consensual "call me" demo).
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_NUMBER=
# Optional, to receive 'engagement complete' notifications on YOUR phone:
# SYBER_OPERATOR_PHONE=+1XXXXXXXXXX

# --- WAF traversal (Cloudflare) — all optional; sensible defaults if unset --------
# Auto-escalation through the WAF layer is ON by default. Set to 0 to disable.
# SYBER_WAF=1
# Point at a per-target tuning file (rate/geo/solver/proxies); see infra/waf.example.yaml.
# SYBER_WAF_CONFIG=infra/waf.example.yaml
# Residential/datacenter proxies for IP rotation (comma-separated). Datacenter IPs
# score worse with Cloudflare; residential/mobile are stronger.
# SYBER_WAF_PROXIES=http://user:pass@host:port,http://user:pass@host2:port
# Interactive-Turnstile solving service (only needed for interactive CAPTCHA).
# SYBER_WAF_CAPTCHA_PROVIDER=2captcha        # or capsolver
# SYBER_WAF_CAPTCHA_KEY=
