DEEPSEEK_API_KEY=

# --- AgentMail: programmatic inboxes for provisioning test accounts (IDOR/BOLA) ---
# Touches only the agent's OWN AgentMail account, never the target.
AGENTMAIL_API_KEY=

# --- AgentPhone: a real number to RECEIVE SMS OTP during test-account signup ------
# Obtain via one-time signup (scripts/syber_phone_signup.sh). Receive-only by design;
# outbound is restricted to SYBER_OPERATOR_PHONE (the consensual "call me" demo).
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_NUMBER=
# Optional, to receive 'engagement complete' notifications on YOUR phone:
# SYBER_OPERATOR_PHONE=+1XXXXXXXXXX
