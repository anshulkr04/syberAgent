agent-browser/**/docs/.next
agent-browser/**/docs/out
agent-browser/**/docs/package-lock.json

# pnpm
agent-browser/**/.pnpm-store

# TypeScript
agent-browser/**/*.tsbuildinfo

# next
agent-browser/**/.next
agent-browser/**/out

