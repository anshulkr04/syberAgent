agent-browser/**/yarn.lock

# Environment
agent-browser/**/.env
agent-browser/**/.env.local

# Windows debug instance config
agent-browser/**/scripts/windows-debug/.instance

# opensrc - source code for packages
agent-browser/**/opensrc

# Docs site
