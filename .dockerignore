# flyctl launch added from .gitignore
# ============================================================================
# Syber Agent — root .gitignore
# ============================================================================

# --- Secrets (NEVER commit) -------------------------------------------------
**/.env
**/.env.*
!**/.env.example
**/*.pem
**/*.key
**/**/secrets

# --- Python virtualenv & caches ---------------------------------------------
**/.venv
**/venv
**/env
**/__pycache__
**/*.py[cod]
**/*$py.class
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/*.egg-info
**/build
**/dist
**/syber-platform/dist/            # packaged Kali image tarball (~1.5 GB)
**/*.tar
**/*.tar.gz

# --- Node ------------------------------------------------------------------
**/node_modules
**/npm-debug.log*
**/yarn-error.log*

# --- Syber runtime state (regenerated at run time) --------------------------
**/.audit_log
**/.memory_store.sqlite
**/.investigation_state
**/.scan_authorization.json
**/**/.audit_log
**/**/.memory_store.sqlite
**/**/.investigation_state
**/**/.scan_authorization.json
**/syber-platform/syber/scoring/calibration/*.joblib

# --- Claude Code / local machine settings -----------------------------------
**/.claude/settings.local.json
**/**/.claude/settings.local.json
**/.claude/projects
**/CLAUDE.local.md

# --- agent-browser (third-party tool clone + its browser/session data) ------
**/agent-browser
**/.agent-browser
**/**/agent-browser-chrome-*
**/*.session.json

# --- OS / editor cruft ------------------------------------------------------
**/.DS_Store
**/.DS_Store?
**/._*
**/Thumbs.db
**/*.swp
**/*~
**/.idea
**/.vscode/*
!**/.vscode/extensions.json

# flyctl launch added from .venv/.gitignore
# Created by venv; see https://docs.python.org/3/library/venv.html
.venv/**/*

# flyctl launch added from agent-browser/.gitignore
# Dependencies
agent-browser/**/node_modules

# Build output
agent-browser/**/dist

# Native binaries (keep the launcher scripts)
agent-browser/**/bin/agent-browser-*
agent-browser/**/bin/.install-method
!agent-browser/**/bin/agent-browser
!agent-browser/**/bin/agent-browser.cmd

# Rust build artifacts
agent-browser/**/cli/target
agent-browser/**/cli/*.o

# Logs
agent-browser/**/*.log
agent-browser/**/npm-debug.log*

# IDE
agent-browser/**/.idea
agent-browser/**/.vscode
agent-browser/**/*.swp
agent-browser/**/*.swo

# OS
agent-browser/**/.DS_Store
agent-browser/**/Thumbs.db

# Python
